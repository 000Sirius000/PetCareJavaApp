<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Activity"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/section_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Walking time and weight history"
        android:textSize="14sp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/section_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/range_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <com.example.petcare.ui.common.ActivityBarChartView
        android:id="@+id/activity_chart"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Walking time chart" />

    <com.example.petcare.ui.common.WeightChartView
        android:id="@+id/weight_chart"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Weight history chart"
        android:visibility="gone" />

    <Button
        android:id="@+id/button_add_primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Add activity" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/section_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/section_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No entries yet"
        android:visibility="gone" />
</LinearLayout>
