<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pet_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Feeding"
        android:textColor="@color/pet_text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/section_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Grams consumed by food type"
        android:textColor="@color/pet_text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button android:id="@+id/button_week" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Week" />
        <Space android:layout_width="8dp" android:layout_height="1dp" />
        <Button android:id="@+id/button_month" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Month" />
        <Space android:layout_width="8dp" android:layout_height="1dp" />
        <Button android:id="@+id/button_year" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Year" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Consumed"
            android:textColor="@color/pet_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/feeding_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total 0 g · Avg 0/day"
            android:textColor="@color/pet_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <com.example.petcare.ui.common.FeedingStackedBarChartView
        android:id="@+id/feeding_chart"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="6dp" />

    <Button
        android:id="@+id/button_add_feeding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Add feeding" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/section_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/section_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No feeding entries yet"
        android:textColor="@color/pet_text_secondary"
        android:visibility="gone" />
</LinearLayout>
