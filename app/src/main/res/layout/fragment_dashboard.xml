<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboard_swipe"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pet_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/dashboard_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/dashboard_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="@color/pet_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/dashboard_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pet_summary_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/pet_surface"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/pet_photo"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:contentDescription="Pet photo"
                            android:src="@android:drawable/ic_menu_gallery" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView android:id="@+id/pet_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Milo" android:textColor="@color/pet_text_primary" android:textSize="20sp" android:textStyle="bold" />
                            <TextView android:id="@+id/pet_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="Dog • Corgi" android:textColor="@color/pet_text_secondary" />

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
                                <TextView android:id="@+id/weight_warning" android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="center_vertical" android:layout_marginEnd="8dp" android:background="@drawable/bg_weight_warning_dot" android:visibility="gone" />
                                <TextView android:id="@+id/pet_weight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No weight recorded yet." android:textColor="@color/pet_text_primary" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/activity_summary_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/pet_surface" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today's activity" android:textColor="@color/pet_text_primary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:id="@+id/activity_rows" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="No activity logged today." android:textColor="@color/pet_text_secondary" android:textSize="15sp" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                            <ProgressBar android:id="@+id/activity_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="8dp" android:layout_gravity="center_vertical" android:layout_weight="1" android:max="100" android:progress="0" />
                            <TextView android:id="@+id/activity_percent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="0%" android:textColor="@color/pet_primary" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/reminders_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/pet_surface" android:orientation="vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Upcoming reminders" android:textColor="@color/pet_text_primary" android:textSize="18sp" android:textStyle="bold" />
                        <LinearLayout android:id="@+id/reminder_rows_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout android:id="@+id/tracker_card" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@color/pet_surface" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Live activity tracker" android:textColor="@color/pet_text_primary" android:textSize="20sp" android:textStyle="bold" />

                    <LinearLayout android:id="@+id/tracker_idle_buttons" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                        <Button android:id="@+id/button_start_walk" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="▶ Walk" />
                        <Space android:layout_width="8dp" android:layout_height="1dp" />
                        <Button android:id="@+id/button_start_run" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="▶ Run" />
                        <Space android:layout_width="8dp" android:layout_height="1dp" />
                        <Button android:id="@+id/button_start_play" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="▶ Play" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/tracker_live_panel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:visibility="gone">
                        <TextView android:id="@+id/tracker_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Live walk tracking" android:textColor="@color/pet_text_secondary" android:textSize="14sp" />
                        <TextView android:id="@+id/tracker_elapsed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="00:00:00" android:textColor="@color/pet_text_primary" android:textSize="32sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tracker_distance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="0.00 km" android:textColor="@color/pet_text_secondary" android:textSize="16sp" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                            <Button android:id="@+id/button_pause_resume_walk" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pause" />
                            <Space android:layout_width="8dp" android:layout_height="1dp" />
                            <Button android:id="@+id/button_finish_walk" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Finish" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/dashboard_empty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="No pets yet — add your first one in Pets" android:textColor="@color/pet_text_secondary" android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
