<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="120dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/pet_thumbnail"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="@string/pet_name"
            android:src="@android:drawable/ic_menu_gallery" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/pet_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Milo"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pet_age_breed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="3 yrs 2 mo — Corgi" />

            <TextView
                android:id="@+id/pet_species"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Dog • Corgi" />

            <TextView
                android:id="@+id/pet_reminders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="2 pending reminders" />

            <TextView
                android:id="@+id/pet_last_activity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Last activity: Walk • 35 min • 2026-01-10" />

            <TextView
                android:id="@+id/pet_next_vaccination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Next vaccination: Rabies • 2026-01-25" />

            <ProgressBar
                android:id="@+id/pet_goal_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="40" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
